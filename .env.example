# Firebase web app config. Create a project at https://console.firebase.google.com,
# enable Email/Password auth and Cloud Firestore, then copy this file to `.env`.
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef

# --- Natural-language step input (Freeplay) ---------------------------------
# Backend for translating typed sentences into proof steps.
#   "mock"     (default) — deterministic, offline, no OpenAI/key needed.
#   "firebase"           — calls the translateStep Cloud Function (needs the
#                          items below + a server-side OPENAI_API_KEY secret).
VITE_FREEPLAY_NL_BACKEND=mock

# App Check (reCAPTCHA v3). Required to call the firebase NL backend in prod.
VITE_FIREBASE_RECAPTCHA_SITE_KEY=
# Dev only: "true" to auto-generate a debug token, or paste a registered token.
VITE_FIREBASE_APPCHECK_DEBUG_TOKEN=
# Cloud Functions region (defaults to us-central1 if unset).
VITE_FIREBASE_FUNCTIONS_REGION=us-central1
