rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // NL translateStep rate-limit counters are managed exclusively by the
    // Cloud Function via the Admin SDK (which bypasses these rules). Deny ALL
    // client access so a learner can't read or tamper with their own quota.
    match /ratelimits/{document=**} {
      allow read, write: if false;
    }
  }
}
