rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // R2-D2 (proof archive): completed freeplay proofs, one doc per solve at
    // users/{uid}/freeplayProofs/{proofId}. Owner-only (private — never
    // world-readable) with minimal shape validation on create. Read/delete are
    // owner-only too. (Reads/writes are also covered by the per-user wildcard
    // above; this block documents intent and validates the stored shape.)
    match /users/{userId}/freeplayProofs/{proofId} {
      allow read, delete: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.puzzleId is string
        && request.resource.data.stepCount is int;
    }

    // In-progress freeplay proofs ("drafts"): at most one doc per puzzle at
    // users/{uid}/freeplayDrafts/{puzzleId}, overwritten on auto-save and
    // deleted on solve/reset. Owner-only (private) with minimal shape
    // validation on write. (Also covered by the per-user wildcard above; this
    // block documents intent and validates the stored shape.)
    match /users/{userId}/freeplayDrafts/{puzzleId} {
      allow read, delete: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.puzzleId is string
        && request.resource.data.stepCount is int;
    }

    // NL translateStep rate-limit counters are managed exclusively by the
    // Cloud Function via the Admin SDK (which bypasses these rules). Deny ALL
    // client access so a learner can't read or tamper with their own quota.
    match /ratelimits/{document=**} {
      allow read, write: if false;
    }
  }
}
